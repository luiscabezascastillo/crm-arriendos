{
  "manifest_version": 3,
  "name": "ENEL Bridge — CRM Arriendos",
  "version": "1.0",
  "description": "Proxy para consultas masivas de deuda ENEL desde CRM Arriendos",
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.enel.cl/*",
    "http://localhost:3000/*",
    "https://crm-arriendos.vercel.app/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://crm-arriendos.vercel.app/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.enel.cl/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ENEL Bridge"
  }
}