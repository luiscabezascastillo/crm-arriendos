{
  "manifest_version": 3,
  "name": "CRM Bridge — Fondo Capital",
  "version": "2.2",
  "description": "Proxy para consultas ENEL (vía Sencillito) y Aguas Andinas desde CRM Arriendos",
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.aguasandinas.cl/*",
    "https://sencillito.com/*",
    "http://localhost:3000/*",
    "https://crm-arriendos.vercel.app/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://crm-arriendos.vercel.app/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.aguasandinas.cl/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://sencillito.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "CRM Bridge"
  }
}
